@model IEnumerable<About>

    <!-- About us -->
    <section id="aa-about-us">
        <div class="container">
            <div class="row">
                @foreach (var item in Model)
                {
                <div class="col-md-12">
                    <div class="aa-about-us-area">
                        <div class="row">
                            <div class="col-md-5">
                                <div class="aa-about-us-left">
                                    <img src=@Url.Content("~/img/" + item.AboutSImg) asp-append-version="true"  />
                                </div>
                            </div>
                            <div class="col-md-7">
                                <div class="aa-about-us-right">
                                    <div class="aa-title">
                                        <h2>@item.AboutTitle</h2>
                                        <span></span>
                                    </div>
                                    <p>
                                        @item.AboutDescription
                                    </p>
                                    
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                }
            </div>
        </div>
    </section>
    <!-- / About us -->