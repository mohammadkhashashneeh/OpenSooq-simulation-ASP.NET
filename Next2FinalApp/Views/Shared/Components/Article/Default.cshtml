@model IEnumerable<Article>


<!-- Latest blog -->
<section id="aa-latest-blog">
    <div class="container">
        <div class="row">
            <div class="col-md-12">
                <div class="aa-latest-blog-area">
                    <div class="aa-title">
                        <h2>Latest News</h2>
                        <span></span>
                        <p>Here you can find Articles</p>
                    </div>
                    <div class="aa-latest-blog-content">
                        <div class="row">
                            @foreach (var item in Model)
                            {

                                <!-- start single blog -->
                                <div class="col-md-4">
                                    <article class="aa-blog-single">
                                        <figure class="aa-blog-img">
                                            <a href="#"><img src=@Url.Content("~/img/" + item.ArticleImg) asp-append-version="true" /></a>
                                            <span class="aa-date-tag">@item.CreationDate</span>
                                        </figure>
                                        <div class="aa-blog-single-content">
                                            <h3><a href="#">@item.ArticleTitle</a></h3>
                                            <p>@item.ArticleDescription</p>
                                            <div class="aa-blog-single-bottom">
                                                <a href="#" class="aa-blog-author"><i class="fa fa-user"></i>@item.UserId</a>
                                                <a href="#" class="aa-blog-comments"><i class="fa fa-comment-o"></i>6</a>
                                            </div>
                                        </div>

                                    </article>
                                </div>
                            }
                            </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- / Latest blog -->